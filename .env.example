# ============================================================
# Pureplay Analytics Ingest — Environment Variables
# Copy to .env and fill in values before starting.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://pureplay:pureplay@localhost:5432/pureplay_ingest

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Webhook auth ---
# WARNING: WEBHOOK_AUTH_MODE=none disables all webhook authentication.
# Never use 'none' in production.
WEBHOOK_AUTH_MODE=none

# Per-vendor API keys (required when WEBHOOK_AUTH_MODE=api_key)
TRACKPRO_API_KEY=
SWINGMETRIC_API_KEY=
PROSWING_API_KEY=

# --- Server ---
PORT=3000
NODE_ENV=development

# --- BullMQ queue config ---
QUEUE_NAME=shot-ingestion
MAX_QUEUE_DEPTH=10000
WORKER_CONCURRENCY=16

# --- Migrations ---
# Set to 'true' to run migrations on startup (never set in prod without review)
RUN_MIGRATIONS=false

# --- Database pool ---
DB_POOL_MAX=20

# --- CORS ---
CORS_ORIGIN=*

# --- Rate limiting ---
# Set THROTTLE_ENABLED=false when running k6 load tests locally so the
# throttler does not reject k6 VUs that all share the 127.0.0.1 bucket.
# NEVER set false in production.
THROTTLE_ENABLED=true

# --- HMAC secrets (required when WEBHOOK_AUTH_MODE=hmac) ---
TRACKPRO_HMAC_SECRET=
SWINGMETRIC_HMAC_SECRET=
PROSWING_HMAC_SECRET=

# --- Internal API key (query / stats / identity / metrics endpoints) ---
# Required in production (min 32 chars). If unset in development, endpoints are
# unprotected and a warning is logged on every request.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=pureplay-analytics-ingest
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
