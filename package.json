{
  "name": "pureplay-analytics-ingest",
  "version": "1.0.0",
  "description": "Pureplay multi-vendor golf shot ingestion and query service",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "start:api": "node -r ./dist/shared/otel/otel.js dist/main.api.js",
    "start:worker": "node -r ./dist/shared/otel/otel.js dist/main.worker.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.api.ts",
    "start:dev:worker": "ts-node -r tsconfig-paths/register src/main.worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:migrate": "ts-node -r tsconfig-paths/register -e \"const {Kysely,PostgresDialect}=require('kysely');const {Pool}=require('pg');const {runMigrations}=require('./src/shared/kysely/migration-runner');const db=new Kysely({dialect:new PostgresDialect({pool:new Pool({connectionString:process.env.DATABASE_URL})})});runMigrations(db).then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.21",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "bullmq": "^5.76.10",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.2",
    "kysely": "^0.29.2",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.21",
    "@swc/core": "^1.10.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "better-sqlite3": "^12.10.0",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.6",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0"
  }
}
